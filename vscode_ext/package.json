{
  "name": "helloworld",
  "displayName": "helloworld",
  "description": "",
  "version": "0.0.4",
  "publisher": "aes",
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "helloworld.helloWorld",
        "title": "開啟 Hello World 面板"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "my-trigger-sidebar",
          "title": "啟動 Dashboard",
          "icon": "icon.png"
        }
      ]
    },
    "views": {
      "my-trigger-sidebar": [
        {
          "type": "webview",
          "id": "my-extension-view",
          "icon": "icon.png",
          "name": "正在啟動..."
        }
      ]
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.102.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "eslint": "^9.39.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
